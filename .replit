language = "html"
modules = ["nodejs-20", "python-3.11"]

[deployment]
deploymentTarget = "static"
publicDir = "/home/runner/workspace/HTML"

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 8001
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 19942
externalPort = 3000

[nix]
packages = ["zip"]

[agent]
expertMode = true
